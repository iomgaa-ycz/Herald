# Herald2 环境配置
# 复制为 .env 后填入真实值

# === Claude CLI 配置（子进程直接读取，不经过 Herald 配置链）===
ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# === Herald 超参数（可选，覆盖 herald.yaml，前缀 HERALD_）===
# 模型名通过此项控制（会作为 --model 传给 CLI，优先级高于 ANTHROPIC_MODEL）
# HERALD_LLM_MODEL=glm-5
# HERALD_LLM_MAX_TOKENS=32768
# HERALD_LLM_MAX_TURNS=16
# HERALD_RUN_MAX_TASKS=3
